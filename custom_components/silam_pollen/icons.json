{
  "services": {
    "manual_update": {
      "service": "mdi:refresh"
    },
    "full_refresh": {
      "service": "mdi:refresh-circle"
    }
  },
  "entity": {
    "sensor": {
      "index": {
        "default": "mdi:progress-question",
        "state": {
          "very_low": "mdi:emoticon-happy-outline",
          "low": "mdi:emoticon-neutral-outline",
          "moderate": "mdi:emoticon-sad-outline",
          "high": "mdi:emoticon-cry-outline",
          "very_high": "mdi:emoticon-dead-outline",
          "unknown": "mdi:progress-question"
        }
      },
      "fetch_duration": {
        "default": "mdi:timer-refresh-outline"
      },
      "forecast_horizon": {
        "default": "mdi:clock-start"
      },
      "alder": {
        "default": "mdi:tree"
      },
      "birch": {
        "default": "mdi:tree-outline"
      },
      "grass": {
        "default": "mdi:grass"
      },
      "hazel": {
        "default": "mdi:hops"
      },
      "mugwort": {
        "default": "mdi:barley"
      },
      "olive": {
        "default": "mdi:grain"
      },
      "ragweed": {
        "default": "mdi:barley"
      },
      "service_status": {
        "default": "mdi:cloud-check-outline",
        "state": {
          "ok": "mdi:cloud-check-outline",
          "service_unavailable": "mdi:cloud-alert-outline",
          "dataset_unavailable": "mdi:database-alert-outline",
          "data_unavailable": "mdi:file-alert-outline",
          "unknown": "mdi:progress-question"
        }
      }
    },
    "weather": {
      "forecast": {
        "default": "mdi:flower-pollen-outline",
        "state": {
          "very_low": "mdi:emoticon-happy-outline",
          "low": "mdi:emoticon-neutral-outline",
          "moderate": "mdi:emoticon-sad-outline",
          "high": "mdi:emoticon-cry-outline",
          "very_high": "mdi:emoticon-dead-outline",
          "unknown": "mdi:progress-question"
        }
      }
    }
  }
}
